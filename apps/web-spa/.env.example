# Public origin of this SPA (no trailing slash). Used for Open Graph image URL when sharing links.
VITE_APP_ORIGIN=http://localhost:5174
VITE_API_URL=http://localhost:3004
# Optional: WebSocket URL (defaults to derived from VITE_API_URL)
VITE_WS_URL=http://localhost:3004
# Must match API ADMIN_SPECTATOR_TOKEN. Set localStorage key "adminToken" to this value to use /games/__admin/ongoing
VITE_ADMIN_TOKEN=